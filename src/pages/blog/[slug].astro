---
import Layout from '../../layouts/Layout.astro';
import posts from '../../data/posts.json';

export async function getStaticPaths() {
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
---

<Layout title={`${post.titulo} | REAXSOL Blog`}>
  <div class="container" style="padding: 2rem 0; max-width: 800px; margin: 0 auto;">
    <p style="font-size: 0.8rem;">
      <a href="/blog" style="color: #000099;">← Volver al blog</a>
    </p>
    <h1 style="color: #000099;">{post.titulo}</h1>
    <p style="color: #666; margin-bottom: 2rem;">{post.fecha}</p>
    {post.miniatura && <img src={post.miniatura} alt={post.titulo} style="width: 100%; max-width: 600px; height: auto; margin-bottom: 1.5rem; border-radius: 0.5rem;">}
    <div style="font-size: 1.05rem; line-height: 1.6;" set:html={post.contenido}></div>
    <hr style="margin: 2rem 0;">
    <p>¿Dudas o comentarios? <a href="/contacto" style="color: #000099;">Contáctenos</a></p>
  </div>
</Layout>