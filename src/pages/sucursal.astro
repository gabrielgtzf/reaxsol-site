---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nuestra sucursal | REAXSOL">
  <div class="container" style="padding: 2rem 0;">
    <h1 style="color: #000099;">Sucursal matriz</h1>
    <p>Visítenos en nuestra única sucursal, donde le atenderemos personalmente.</p>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-top: 2rem;">
      <div>
        <h2 style="color: #000099;">Dirección</h2>
        <p><strong>Vicente Guerrero No. 20</strong><br>
        Col. Urbana Ixhuatepec<br>
        Ecatepec de Morelos, Estado de México<br>
        C.P. 55349</p>
        <h3 style="color: #000099;">Horarios de atención</h3>
        <p>Lunes a viernes: 9:00 – 18:00 hrs<br>
        Sábados: 9:00 – 14:00 hrs<br>
        Domingo: cerrado</p>
        <h3 style="color: #000099;">Teléfonos</h3>
        <p>55 5715 1454<br>55 5715 1579</p>
        <h3 style="color: #000099;">Correo</h3>
        <p>servicios@reaxsol.com</p>
      </div>
      <div>
        <!-- Mapa estático de Google Maps (placeholder) -->
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3760.5733311722006!2d-99.08739650000001!3d19.516984200000003!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85d1fa11caf9d745%3A0x347ae9b2c19cd261!2sREACTIVOS%20Y%20RESINAS!5e0!3m2!1ses!2smx!4v1780761376250!5m2!1ses!2smx"
          width="100%" 
          height="300" 
          style="border:0; border-radius:0.5rem;" 
          allowfullscreen="" 
          loading="lazy">
        </iframe>
        <p class="text-center" style="font-size:0.8rem; margin-top:0.5rem;">(Mapa ilustrativo – la ubicación exacta se mostrará con su dirección real).</p>
      </div>
    </div>
  </div>
</Layout>