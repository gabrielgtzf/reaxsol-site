---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto | REAXSOL">
  <div class="container" style="padding: 2rem 0; max-width: 800px;">
    <h1 style="color: #000099;">Contacto</h1>
    <p>Estamos para servirle. Elija el medio que prefiera.</p>

    <div style="background-color: var(--gris-claro); padding: 1.5rem; border-radius: 0.5rem; margin-bottom: 2rem;">
      <h3>Formulario rápido</h3>
      <form action="/gracias" method="post" data-netlify="true" netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="contacto-general">
        <div style="margin-bottom: 1rem;">
          <label>Nombre *</label>
          <input type="text" name="nombre" required style="width: 100%; padding: 0.5rem;">
        </div>
        <div style="margin-bottom: 1rem;">
          <label>Correo *</label>
          <input type="email" name="email" required style="width: 100%; padding: 0.5rem;">
        </div>
        <div style="margin-bottom: 1rem;">
          <label>Mensaje *</label>
          <textarea name="mensaje" rows="4" required style="width: 100%; padding: 0.5rem;"></textarea>
        </div>
        <button type="submit" class="btn btn-primary" style="background-color: #000099; color: #ffff00;">Enviar mensaje</button>
      </form>
    </div>

    <div>
      <h3>Otros medios</h3>
      <p><strong>Teléfono:</strong> 55 5715 1454 / 55 5715 1579</p>
      <p><strong>WhatsApp:</strong> <a href="https://wa.me/525557151454">55 5715 1454</a></p>
      <p><strong>Correo:</strong> servicios@reaxsol.com</p>
      <p><strong>Tienda física:</strong> Vicente Guerrero No. 20, Ecatepec (ver <a href="/sucursal">ubicación</a>)</p>
    </div>
  </div>
</Layout>